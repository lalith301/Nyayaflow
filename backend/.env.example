# ─── LLM (required always) ───────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Get free at: https://console.groq.com

# ─── Deployment mode ─────────────────────────────────────────────────────────
# "local"      → ChromaDB on disk + local SentenceTransformer + faster-whisper
# "production" → Qdrant Cloud + HuggingFace API + Groq Whisper API
DEPLOY_MODE=local

# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_DEBUG=true
FLASK_PORT=8000

# ─── Local mode settings ─────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
PDF_DATA_PATH=./data/pdfs

# ─── Production mode settings (only needed when DEPLOY_MODE=production) ──────
# Qdrant Cloud — free tier at https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# HuggingFace — free token at https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_token_here
